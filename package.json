{
  "name": "nice-react-styles",
  "version": "5.0.1",
  "type": "module",
  "description": "React provider component for nice-styles CSS variables with styled-components theme support",
  "main": "dist/index.js",
  "module": "dist/index.esm.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.esm.js",
      "require": "./dist/index.js",
      "default": "./dist/index.esm.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rollup -c",
    "dev": "rollup -c -w",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build",
    "prepare": "npm run build"
  },
  "peerDependencies": {
    "react": ">=19.2.0 <20.0.0",
    "react-dom": ">=19.2.0 <20.0.0",
    "styled-components": ">=6.1.18 <7.0.0"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^25.0.7",
    "@rollup/plugin-node-resolve": "^15.2.3",
    "@rollup/plugin-typescript": "^11.1.5",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "nice-configuration": "file:../configuration",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "rollup": "^4.9.1",
    "rollup-plugin-dts": "^6.1.0",
    "rollup-plugin-peer-deps-external": "^2.2.4",
    "styled-components": "6.1.19",
    "tslib": "^2.6.2",
    "typescript": "^6.0.3"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "keywords": [
    "react",
    "css",
    "css-variables",
    "custom-properties",
    "design-tokens",
    "design-system",
    "theming",
    "nice",
    "provider",
    "context"
  ],
  "author": "Mohammed Ibrahim",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/niceprototypes/nice-react-styles.git"
  },
  "bugs": {
    "url": "https://github.com/niceprototypes/nice-react-styles/issues"
  },
  "homepage": "https://github.com/niceprototypes/nice-react-styles#readme",
  "dependencies": {
    "nice-styles": "file:../styles"
  }
}
